train_config {
  sparse_optimizer {
    adagrad_optimizer {
      lr: 0.002
    }
    constant_learning_rate {
    }
  }
  dense_optimizer {
    adam_optimizer {
      lr: 0.001
    }
    constant_learning_rate {
    }
  }
  num_epochs: 1
  save_checkpoints_steps: 0
  use_tensorboard: false
  save_checkpoints_epochs: 1
}
eval_config {
}
export_config {
}
data_config {
  batch_size: 4096
  dataset_type: OdpsDataset
  label_fields: "is_click"
  num_workers: 24
  shuffle: false
  fg_mode: FG_BUCKETIZE
  odps_data_compression: "ZSTD"
}
# ===== id_feature (user) =====
feature_configs {
  id_feature {
    feature_name: "mmb_id"
    expression: "user:mmb_id"
    embedding_dim: 32
    zch {
      zch_size: 1810299
      eviction_interval: 2
      lfu {}
      threshold_filtering_func: "lambda x: dynamic_threshold_filter(x, 3.0)"
    }
  }
}
