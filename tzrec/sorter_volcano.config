 volcano_rank {
    deep {
        hidden_units: [512,256,128]
        use_ln: true
        dropout_ratio: 0.1
    }
    cdot {
        output_dim: 4
        mid_dim: 32
        compress_hidden_units: [512, 256]
    }
    bias {
        hidden_units: [512,256,128,64]
        use_ln: true
        dropout_ratio: 0.1
    }
    use_lhuc: true
    lhuc_gate {
        hidden_units: [256]
    }
    final {
        hidden_units: [512,256,128,1]
        use_ln: true
        dropout_ratio: 0.1
    }
}
    num_class: 1
    metrics {
        auc {}
    }
    train_metrics {
        auc {
        }
    }
    losses {
        binary_cross_entropy {
          label_smoothing: 0.0
        }
    }
}
