    group_type: DEEP
  }
  losses {
    softmax_cross_entropy {
    }
  }
  metrics {
    recall_at_k {
      top_k: 1
    }
  }
  metrics {
    recall_at_k {
      top_k: 10
    }
  }
  dssm {
    in_batch_negative: true
    similarity : COSINE
    temperature: 0.2
    user_tower {
      input: "user"
      mlp {
        use_bn: true
        hidden_units: [512, 256, 128]
      }
    }
    item_tower {
      input: "item"
      mlp {
        use_bn: true
        hidden_units: [512, 256, 128]
      }
    }
    output_dim: 64
  }
}
