train_config {
  sparse_optimizer {
    adam_optimizer {
      lr: 0.001
    }
    constant_learning_rate {
    }
  }
  dense_optimizer {
    adam_optimizer {
      lr: 0.001
    }
    constant_learning_rate {
    }
  }
  num_epochs: 1
  use_tensorboard: false
  save_checkpoints_epochs: 1
}
eval_config {
}
export_config {
}
data_config {
  batch_size: 1024
  dataset_type: OdpsDataset
  label_fields: "is_click"
  num_workers: 42
  fg_mode: FG_DAG
  odps_data_compression: "ZSTD"
}
